import React, { useCallback, useEffect, useState } from "react";
import { useDispatch, useSelector } from "react-redux";
import { MDBBtn, MDBCol, MDBDatePicker, MDBIcon, MDBRow, MDBSpinner, MDBTypography } from "mdbreact";

import "../learner.css";
import { FindStudent } from "../../../../../../services/redux/slices/registrar/students";
import moment from "moment";
import resetUserDetails from "./resetForm";

const Identify = ({
    setDetails,
    data,
    setUserData,
    isRegistrar,
    batches,
    openBatch,
    setState,
    resetForm,
    handleBlockNextBtn = () => { }
}) => {
    const { token } = useSelector(({ auth }) => auth);
    const { student, isLoadingAllStudents } = useSelector(
        ({ students }) => students
    );
    const [_student, setStudent] = useState({});
    const [searchQuery, setSearchQuery] = useState("");
    const [errorMsg, setErrorMsg] = useState(false);
    const [isUserFound, setIsUserFound] = useState(false);
    const [user, setUser] = useState({});
    const [searchEmail, setSearchEmail] = useState("");
    const [emailExist, setEmailExist] = useState(false);
    const dispatch = useDispatch();

    const handleDateChange = (value) => {
        if (moment(value).isValid()) {
            setDetails({ ...data, dob: value });
            setUserData((prev) => ({ ...prev, dob: value }));
        }
    };

    const updateUserDetails = useCallback(
        async (studentData) => {
            if (!studentData.student) {
                setState({});
                return;
            }
            const { student, ...data } = studentData;
            setState({ ...student, studentId: student._id, ...data });

            setIsUserFound(true);
            setUser({
                sy: studentData?.batch?.sy,
                status: studentData.status,
            });
        },
        [setState]
    );

    const handleInputChange = (key, value) => {
        if (key === "mobile") {
            if (value.length >= 12) {
                value = value.slice(0, 12);
            }
        }

        if (key === "isMale") {
            value = value === "Male" ? true : false;
        }

        console.log("changed");
        setDetails({ ...data, [key]: value });
        setUserData((prev) => ({ ...prev, [key]: value }));
    };

    const handleObjectInputChange = (obj, key, value) => {
        const _obj = { ...data[obj] };
        _obj[key] = value;

        setDetails({ ...data, [obj]: _obj });
        setUserData((prev) => ({ ...prev, [obj]: _obj }));
    };

    const handleSearchByLrn = useCallback(() => {
        if (searchQuery.length !== 12 || batches.length === 0) {
            setErrorMsg("Please provide the exact LRN.");
            return;
        }

        if (Object.keys(_student).length === 0) {
            setIsUserFound(false);
            setErrorMsg("No student found with this LRN");
            setDetails((prev) => ({ ...resetUserDetails, LRN: prev.LRN, }))
            setUserData((prev) => ({ ...resetUserDetails, LRN: prev.LRN, }))
        } else {
            setErrorMsg("");
            setIsUserFound(true);
        }

        if (isRegistrar) {
            updateUserDetails(_student);
        }

        // eslint-disable-next-line react-hooks/exhaustive-deps
    }, [
        searchQuery,
        batches,
        _student,
        openBatch,
        setErrorMsg,
        updateUserDetails,
    ]);


    const handleCheckUniqueValues = (key, value) => {
        if (key === "LRN") {

            if (value.length >= 12) {
                value = value.slice(0, 12);
            }
            setSearchQuery(value);

            if (!isRegistrar && Object.values(_student).length > 0 && value.length >= 12) {
                handleBlockNextBtn(true)
                setErrorMsg(`${value} Already exist`);
            } else {
                handleBlockNextBtn(false)
            }

            handleInputChange(key, value);

            return;
        }

        setSearchEmail(value);
        handleInputChange(key, value);
    };

    useEffect(() => {
        if (searchQuery.length === 12 || data.LRN.length === 12) {
            const allBatch = batches.map((batch) => batch._id);
            dispatch(
                FindStudent({
                    token,
                    data: { batches: allBatch, data: { LRN: data.LRN } },
                })
            );
        }
        // eslint-disable-next-line react-hooks/exhaustive-deps
    }, [searchQuery, dispatch, data.LRN]);

    useEffect(() => {
        if (searchEmail) {
            const allBatch = batches.map((batch) => batch._id);
            dispatch(
                FindStudent({
                    token,
                    data: { batches: allBatch, data: { email: data.email } },
                })
            );
        }
        // eslint-disable-next-line react-hooks/exhaustive-deps
    }, [searchEmail, dispatch]);

    useEffect(() => {
        if (student) {

            console.log(student);
            if (student?.searchUsing === "LRN") {
                setStudent(student);
            }

            if (!isRegistrar && Object.values(student).length > 0) {
                handleBlockNextBtn(true)
                setErrorMsg(`${student.LRN} Already exist`);
            } else if (!isRegistrar && Object.values(student).length === 0) {
                handleBlockNextBtn(false)
                setErrorMsg(``);
            }

            if (isRegistrar && student.searchUsing === "email") {
                setEmailExist(true);
            }
        }
        
        // eslint-disable-next-line react-hooks/exhaustive-deps
    }, [student]);

    useEffect(() => {
        if (_student && searchQuery.length >= 12 && isRegistrar) {
            handleSearchByLrn();
        }
        // eslint-disable-next-line react-hooks/exhaustive-deps
    }, [searchQuery, _student]);

    useEffect(() => {
        if (resetForm) {
            setIsUserFound(false);
        }
    }, [resetForm]);


    useEffect(() => {
        let timeoutId;
        if (errorMsg) {
            timeoutId = setTimeout(() => {
                setErrorMsg("");
            }, 3000);
        }
        return () => {
            clearTimeout(timeoutId);
        };
    }, [errorMsg]);

    useEffect(() => {
        let timeoutId;
        if (emailExist) {
            timeoutId = setTimeout(() => {
                setEmailExist(false);
            }, 3000);
        }
        return () => {
            clearTimeout(timeoutId);
        };
    }, [emailExist]);

    return (
        <>
            <MDBRow style={{ backgroundColor: "#0000FF" }}>
                <MDBCol>
                    <h5 className="font-weight-bold text-white label mt-2 mb-2 ml-5 section-title">
                        I. LEARNER INFORMATION
                    </h5>
                </MDBCol>
            </MDBRow>
            {isRegistrar && isUserFound && (
                <MDBRow className="mt-2">
                    <MDBCol>
                        <MDBTypography
                            variant="h2"
                            className="mb-0 text-black-50"
                            noteColor="success"
                            note
                            noteTitle={user.sy}
                        >
                            <span>: </span> {user.status}
                        </MDBTypography>
                    </MDBCol>
                </MDBRow>
            )}
            <MDBRow className="mx-4">
                <MDBCol sm="6" lg="3" md="5">
                    <h6 className="mt-4">
                        <strong>
                            <span className="red-text">*</span>Learner Reference No.
                        </strong>
                    </h6>
                    <input
                        type="number"
                        placeholder="LRN"
                        value={data.LRN || ""}
                        name="LRN"
                        className="form-control"
                        onChange={(e) =>
                            handleCheckUniqueValues(e.target.name, e.target.value)
                        }
                        min={1}
                        maxLength={12}
                        pattern="[0-9]*"
                    />
                </MDBCol>
                {isRegistrar && (
                    <MDBCol className="d-flex align-items-end p-0" md="2">
                        {isLoadingAllStudents ? (
                            <MDBSpinner small role="status"></MDBSpinner>
                        ) : (
                            <MDBBtn
                                color="primary"
                                className="btn Ripple-parent btn-sm btn-outline-white btn-rounded d-inline ml- px-2"
                                onClick={() => handleSearchByLrn()}
                            >
                                <MDBIcon icon="search" />
                            </MDBBtn>
                        )}
                    </MDBCol>
                )}
            </MDBRow>
            <MDBRow className="mb-4 mr-4 ml-4">
                <MDBCol>
                    {errorMsg && <small className="text-danger">{errorMsg}</small>}
                </MDBCol>
            </MDBRow>

            <MDBRow className="mt-4 mr-4 ml-4">
                <MDBCol>
                    <h6>
                        <strong>Fullname</strong> - <i>Enter your full name correctly</i>
                    </h6>
                </MDBCol>
            </MDBRow>
            <MDBRow className="mb-4 mr-4 ml-4 fullName">
                <MDBCol sm="6" lg="3" className="mt-3">
                    <h6>
                        <span className="red-text">*</span>First Name
                    </h6>

                    <input
                        type="text"
                        className="form-control"
                        placeholder="First Name"
                        name="fname"
                        value={data.fullName?.fname || ""}
                        onChange={(e) =>
                            handleObjectInputChange("fullName", e.target.name, e.target.value.toUpperCase())
                        }
                        readOnly={!isRegistrar}
                    />
                </MDBCol>
                <MDBCol sm="6" lg="3" className="mt-3">
                    <h6>Middle Name</h6>

                    <input
                        type="text"
                        className="form-control"
                        placeholder="Middle Name"
                        name="mname"
                        value={data.fullName?.mname || ""}
                        onChange={(e) =>
                            handleObjectInputChange("fullName", e.target.name, e.target.value.toUpperCase())
                        }
                        readOnly={!isRegistrar}
                    />
                </MDBCol>
                <MDBCol sm="6" lg="3" className="mt-3">
                    <h6>
                        {" "}
                        <span className="red-text">*</span>Last Name
                    </h6>

                    <input
                        type="text"
                        className="form-control"
                        placeholder="Last Name"
                        name="lname"
                        value={data.fullName?.lname || ""}
                        onChange={(e) =>
                            handleObjectInputChange("fullName", e.target.name, e.target.value.toUpperCase())
                        }
                        readOnly={!isRegistrar}
                    />
                </MDBCol>
                <MDBCol sm="6" lg="3" className="mt-3">
                    <h6>Suffix</h6>

                    <input
                        type="text"
                        className="form-control"
                        placeholder="Suffix"
                        name="suffix"
                        value={data.fullName?.suffix || ""}
                        onChange={(e) =>
                            handleObjectInputChange("fullName", e.target.name, e.target.value.toUpperCase())
                        }
                        readOnly={!isRegistrar}
                    />
                </MDBCol>
            </MDBRow>

            <MDBRow className="mb-4 mr-4 ml-4 ">
                <MDBCol sm="6" lg="3" className="mt-3">
                    <h6>Place of birth </h6>

                    <input
                        placeholder="Place of Birth"
                        className="form-control"
                        value={data.birthplace || ""}
                        name="birthplace"
                        onChange={(e) => handleInputChange(e.target.name, e.target.value.toUpperCase())}
                        readOnly={!isRegistrar}
                    />
                </MDBCol>
                <MDBCol sm="6" lg="3" className="mt-3">
                    <h6>
                        <span className="red-text">*</span>Date of birth{" "}
                    </h6>

                    {data.dob === "" ? (
                        <MDBDatePicker getValue={handleDateChange} value={data.dob ? new Date(data.dob).toDateString() : new Date()} />
                    ) : (
                        <input
                            placeholder="Date of Birth"
                            className="form-control"
                            type="text"
                            value={new Date(data.dob).toDateString() || ""}
                            name="dob"
                            onChange={(e) => handleInputChange(e.target.name, e.target.value)}
                            readOnly={!isRegistrar}
                        />
                    )}

                </MDBCol>
                <MDBCol sm="6" lg="3" className="mt-3">
                    <h6>
                        <span className="red-text">*</span>Gender
                    </h6>
                    <select
                        className="form-control"
                        name="isMale"
                        value={data.isMale ? "Male" : "Female"}
                        onChange={(e) => handleInputChange(e.target.name, e.target.value)}
                        readOnly={!isRegistrar}
                    >
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                </MDBCol>
                <MDBCol sm="6" lg="3" className="mt-3">
                    <h6>
                        <span className="red-text">*</span>Phone No.
                    </h6>
                    <input
                        placeholder="Phone No."
                        className="form-control"
                        type="number"
                        value={data.mobile || ""}
                        name="mobile"
                        onChange={(e) => handleInputChange(e.target.name, e.target.value)}
                        readOnly={!isRegistrar}
                    />
                </MDBCol>
            </MDBRow>
            {(isRegistrar && !isUserFound && searchQuery.length > 0) && (
                <>
                    <MDBRow style={{ backgroundColor: "#0000FF" }}>
                        <MDBCol>
                            <h5 className="font-weight-bold text-white label mt-2 mb-2 ml-5 section-title">
                                I.I ACCOUNT INFORMATION
                            </h5>
                        </MDBCol>
                    </MDBRow>
                    <MDBRow className="mt-4 mr-4 ml-4">
                        <MDBCol className="mt-3">
                            <h6>
                                <strong>Account Information</strong> -{" "}
                                <i>Double check the email and password</i>
                            </h6>
                        </MDBCol>
                    </MDBRow>
                    <MDBRow className="mt-4 mr-4 ml-4">
                        <MDBCol sm="6" lg="3" md="4" className="mt-3">
                            <h6>
                                <strong>
                                    <span className="red-text">*</span>Email
                                </strong>
                            </h6>
                            <input
                                type="email"
                                placeholder="email"
                                value={data.email || ""}
                                name="email"
                                className="form-control"
                                onChange={(e) =>
                                    handleCheckUniqueValues(e.target.name, e.target.value)
                                }
                                required
                            />

                            <MDBRow>
                                <MDBCol>
                                    {emailExist && <small className="text-danger">Email already exist!</small>}
                                </MDBCol>
                            </MDBRow>
                        </MDBCol>
                        <MDBCol sm="6" lg="3" md="4" className="mt-3">
                            <h6>
                                <strong>
                                    <span className="red-text">*</span>Password
                                </strong>
                            </h6>
                            <input
                                type="text"
                                placeholder="password"
                                value={data.password || ""}
                                name="password"
                                className="form-control"
                                onChange={(e) =>
                                    handleInputChange(e.target.name, e.target.value)
                                }
                                required
                            />
                        </MDBCol>
                    </MDBRow>
                </>
            )}
        </>
    );
};

export default Identify;

