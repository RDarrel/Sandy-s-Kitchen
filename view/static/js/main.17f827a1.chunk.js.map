import { MDBBtn, MDBCardBody, MDBCardHeader, MDBCol, MDBRow } from 'mdbreact';
import React from 'react'
import { RESET, SETROUTE } from '../../../../../../services/redux/slices/auth';
import { useHistory } from "react-router";
import { useDispatch } from 'react-redux';

const ApprovedCard = ({ isMale, fullName, openForm, showForm }) => {
    const history = useHistory();
    const dispatch = useDispatch();


  return (
    <>
        <MDBCardHeader className="bg-white">
            <MDBRow>
                <MDBCol>Status: 
                    <span className="green-text font-weight-bold ml-2">
                        ENROLLED
                    </span>
                </MDBCol>
            </MDBRow>
        </MDBCardHeader>
        <MDBCardBody>
            <MDBRow>
                <MDBCol>
                    <div style={{ fontSize: "1rem" }}>
                    <strong>
                        Dear {isMale ? "Mr." : "Ms."}
                        {fullName.fname} {fullName.lname}
                    </strong>{" "}
                    <p style={{ lineHeight: "28px" }} className="mt-2">
                        Congratulations! Your enrollment form has been approved,
                        and you are now officially part of &nbsp;
                        <strong>Leonor M. Bautista National High School</strong>.
                        Welcome to our school community! As you start your journey
                        with us, we kindly remind you of some important school
                        rules:
                    </p>
                    <ol style={{ lineHeight: "35px", fontSize: "16px", opacity: ".8", textAlign: "left" }}>
                        <li>
                        Attendance and punctuality are crucial for academic
                        success. Please ensure you arrive on time for classes
                        and activities.
                        </li>
                        <li>
                        Respect for teachers, staff, and fellow students is
                        paramount. We promote a positive and inclusive learning
                        environment for everyone.
                        </li>
                        <li>
                        Adherence to the school's dress code policy is required
                        at all times.
                        </li>
                        <li>
                        Participation in extracurricular activities and school
                        events is encouraged to enrich your educational
                        experience.
                        </li>
                        <li>
                        For any concerns or inquiries, do not hesitate to reach
                        out to our school administration or guidance counselors.
                        </li>
                    </ol>
                    We are excited to have you join our school community and
                    wish you a fulfilling and successful academic year!{" "}
                    </div>
                </MDBCol>
            </MDBRow>
            <MDBRow>
                <MDBCol>
                    <MDBBtn
                        color="primary"
                        size='md'
                        onClick={() => {
                        history.push("/schedule");
                        dispatch(SETROUTE("schedule"));
                        dispatch(RESET());
                        }}
                    >
                        View Schedule
                    </MDBBtn>
                    {showForm && (
                        <MDBBtn
                            color="primary"
                            size='md'
                            onClick={() => openForm(true) }

                        >
                            Enroll
                        </MDBBtn>
                    )}
                </MDBCol>
            </MDBRow>
        </MDBCardBody>
    </>
  )
}

export default ApprovedCard