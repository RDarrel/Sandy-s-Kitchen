import { MDBAvatar, MDBBtn, MDBCardBody, MDBCardHeader, MDBCol, MDBRow } from 'mdbreact'
import React from 'react'
import { PresetImage } from '../../../../../../services/utilities'
import { Header } from '../headers';

const DropCard = ({ setResolveIssue, student, fullName, auth, mobile, address, picture, isEnrollmentOpen}) => {
  return (
    <>
      <MDBCardHeader className="bg-white">
        <MDBRow>
          <MDBCol>
            <div className="pb-3">
              <Header />
            </div>
          </MDBCol>
        </MDBRow>
      </MDBCardHeader>
      <MDBCardBody>
        <div
          className="d-flex align-items-center justify-content-center w-100 dropOut-banner-container"
          style={{ position: "absolute", top: "40%" }}
        >
          <div
            className="d-flex align-items-center justify-content-center dropOut-banner"
            style={{
              textAlign: "center",
              fontSize: "100px",
              fontWeight: "bold",
              color: "red",
              transform: "rotate(-30deg)",
              border: "7px solid",
              padding: "0 20px",
              backgroundColor: "#d9d9d975",
              zIndex: "1",
            }}
          >
            DROP OUT
          </div>
        </div>
        <MDBRow className="profile-row" style={{ opacity: ".8" }}>
          <MDBCol md="9" className="mt-4 info-section">
            <div>
              <h5 className="pb-3">
                <strong>LRN:</strong> {student.credentials?.LRN.toUpperCase()}
              </h5>
              <h5 className="pb-3">
                <strong>NAME:</strong>{" "}
                {(
                  fullName.fname +
                  " " +
                  fullName.mname +
                  " " +
                  fullName.lname
                ).toUpperCase()}
              </h5>
              <h5 className="pb-3">
                <strong>GRADE:</strong>
                {(student.enrolleeData?.strand
                  ? student.enrolleeData?.strand.toUpperCase() + " "
                  : "") +
                  (
                    student.enrolleeData?.lvl +
                    " " +
                    student.enrolleeData?.section?.name
                  ).toUpperCase()}
              </h5>
              <h5 className="pb-3">
                <strong>PROGRESS:</strong>{" "}
                {student.enrolleeData?.progress.toUpperCase()}
              </h5>
              <h5 className="pb-3">
                <strong>SY:</strong>{" "}
                {student.enrolleeData?.batch?.sy.toUpperCase()}
              </h5>
              <h5 className="pb-3">
                <strong>MOBILE:</strong> {mobile.toUpperCase()}
              </h5>
              <h5 className="pb-3">
                <strong>ADDRESS:</strong>{" "}
                {(
                  address.current?.barangay +
                  " " +
                  address.current?.city +
                  " " +
                  address.current?.province
                ).toUpperCase()}
              </h5>
            </div>
          </MDBCol>
          <MDBCol md="3" className="mt-4 profile-section">
            <MDBAvatar
              tag="img"
              src={picture}
              onError={(e) => (e.target.src = PresetImage(auth.isMale))}
              alt={`preview-${auth._id}`}
              className="z-depth-1 mb-3 mx-auto rounded student-picture"
              style={{ width: "100%" }}
            />
          </MDBCol>
        </MDBRow>
        <MDBRow>
          <MDBCol md="12" className="mt-4 drop-message">
            <h5 className="msg-txt">
              {" "}
              <b>
                We regret to inform you that your enrollment process has been
                classified as dropped out. Should you need any clarification or
                support, please don't hesitate to reach out to us. We are here
                to help you.
                <br />
                <br />
                Thank you for your understanding.
              </b>
            </h5>
          </MDBCol>
        </MDBRow>
        <MDBRow>
          {isEnrollmentOpen && (
            <MDBCol className="d-flex justify-content-start enrollBtn-cont">
              <MDBBtn
                color="primary"
                size='md'
                onClick={() => setResolveIssue(true)}
              >
                Enroll
              </MDBBtn>
            </MDBCol>
          )}
        </MDBRow>
      </MDBCardBody>
    </>
  );
};

export default DropCard;
