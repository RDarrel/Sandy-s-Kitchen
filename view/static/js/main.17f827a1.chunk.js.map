import { MDBCol, MDBRow } from 'mdbreact'
import React, { useEffect, useRef, useState } from 'react';
import Images from '../../../../../../widgets/Image';
import { useSelector } from 'react-redux';
import checkIfBlurredImg from '../imageTools/canvasCheckBlurred';
import { useToasts } from 'react-toast-notifications';

import "../learner.css";
const Documents = ({ setDetails, data, handleBlockNextBtn, isRegistrar, isNewStudent, setUserData}) => {
    const { auth } = useSelector(({ auth }) => auth)
    const imageKeys = ["studentPicture", "signature", "PSA", "card", "clearance"];
    const initializeImageData = (data) => {
        return imageKeys.reduce((acc, key) => {
          acc[key] = data[key] instanceof File ? URL.createObjectURL(data[key]) : data[key];
          return acc;
        }, {});
    };
    const [userDataImage, setUserDataImage] = useState(initializeImageData(data));

    const prevImage = useRef(initializeImageData(data)).current;
    const { addToast } = useToasts();

    useEffect(() => {
        setUserDataImage(previous => ({   
            ...previous, 
            email: isRegistrar ? data.email : auth.email, 
            _id: isRegistrar ? data.studentId : auth._id, 
            filesData: {
                hasStudentPicture: data.hasStudentPicture, 
                hasSignature: data.hasSignature, 
                hasPSA: data.hasPSA,
                hasCard: data.hasCard,
                hasClearance: data.hasClearance
            }
        }));
    }, [data.hasStudentPicture, data.hasSignature, data.hasPSA, data.hasCard, data.hasClearance, auth.email, auth._id, data.email, data._id, data.studentId, isRegistrar]);

    const handleChange = (e) => {
        const { name, files } = e.target;
        
        if (files.length > 0) {
            const file = files[0];


            setDetails({
                ...data,
                [name]: file,
            });

            const fileUrl = URL.createObjectURL(file)
            setUserDataImage((prev) => ({
                ...prev,
                [name]: fileUrl
            }));

            const reader = new FileReader();
            reader.onload = (e) => {
                const base64String = e.target.result;
                setUserData((prev) => ({
                    ...prev,
                    [name]: base64String,
                }));

                const img = new Image();
                img.onload = () => {
                    const imgBlurred2 = checkIfBlurredImg(img)
                    handleBlockNextBtn(imgBlurred2)

                    if(imgBlurred2){
                        addToast(`Error cannot process blurry image of ${name}`, {
                            appearance: "error",
                        });
                        
                        Object.keys(prevImage).forEach(key => {
                            if(key === name){
                                setDetails({
                                    ...data,
                                    [name]: prevImage[key],
                                });
                                setUserData((prev) => ({
                                    ...prev,
                                    [name]: prevImage[key],
                                }));

                                if (prevImage[key] instanceof Blob || prevImage[key] instanceof File) {
                                    const fileUrl = URL.createObjectURL(prevImage[key]);
                                    setUserDataImage((prev) => ({
                                        ...prev,
                                        [name]: fileUrl
                                    }));
                                }
                            }
                        });
                    }

                };
                img.src = e.target.result; 
            };
            reader.readAsDataURL(file);
        }
    };

    return (
        <>
            <MDBRow style={{ backgroundColor: "#0000FF" }}>
                <MDBCol>
                <h5 className="font-weight-bold text-white label mt-2 mb-2 ml-5 section-title">
                    IV. CREDENTIALS
                </h5>
                </MDBCol>
            </MDBRow>

            <MDBRow>
                <h6 className="ml-5 mt-4 font-weight-bold label mt-2 mb-2 ml-5">
                <strong>Documents</strong> -
                <i>
                    upload all your documents.
                </i>
                <br />
                <i>
                  Important: Only JPEG, JPG, and PNG files are allowed.
                </i>
                </h6>
            </MDBRow>
            
            <MDBRow className='mt-4'>
                <Images
                    userDataImage={userDataImage}
                    handleChange={handleChange}
                    viewOnly = {false}
                    imageTypes={['studentPicture', 'signature', 'PSA', 'card', 'clearance']}
                    lvl={data.lvl}
                    isNewStudent={isNewStudent}
                />
            </MDBRow>
        </>
    );
}

export default Documents