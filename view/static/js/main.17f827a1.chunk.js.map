import React from "react";
import { MDBCol, MDBRow } from "mdbreact";

import Identify from "../identify";
import Health from "../health";
import Address from "../address";
import Parents from "../parents";
import Documents from "../documents";
import Enrollment from "../enrollment";

const Body = ({ 
    batches, 
    openBatch, 
    setDetails, 
    details, 
    _doneSteps, 
    stepCount, 
    isNewReject, 
    setUserData, 
    handleBlockNextBtn, 
    isRegistrar, 
    handleObjChange,
    setState,
    resetForm,
    isNewStudent
  }) => {
    const renderSteps = () => {
    switch (stepCount) {
      case 1:
        return (
          <Identify 
            setDetails={setDetails} 
            data={details} 
            setUserData={setUserData} 
            isRegistrar={isRegistrar} 
            batches={batches} 
            openBatch={openBatch}
            handleBlockNextBtn={handleBlockNextBtn}
          />
        );
      case 2:
        return (
          <Address 
            addressInfo={details} 
            handleObjChange={handleObjChange} 
          />
        );
      case 3:
        return (
          <Health 
            setDetails={setDetails} 
            data={details} 
            setUserData={setUserData} 
            handleObjChange={handleObjChange} 
          />
        );
      case 4:
        return (
          <Parents 
            setDetails={setDetails} 
            data={details} 
            setUserData={setUserData} 
          />
        );
      case 5:
        return (
          <Documents 
            setDetails={setDetails} 
            setUserData={setUserData} 
            data={details} 
            handleBlockNextBtn={handleBlockNextBtn} 
            isRegistrar={isRegistrar} 
            isNewStudent={isNewStudent}
          />
        )
      case 6:
        return (
          <Enrollment
            collections={batches}
            setDetails={setDetails}
            data={details}
            isNewNReject={isNewReject}
            setUserData={setUserData}
            handleBlockNextBtn={handleBlockNextBtn}
          />
        );
      default:
        break;
    }
  };

  return (
    <>
      <MDBRow className="m-2">
        <MDBCol className="p-0">
          {stepCount === 1 && (
            <h6 className="mt-4">
              <strong>Description:</strong>{" "}
              <i>
                This form has {_doneSteps.length} steps that need to be
                completed to have a successful enrollment. Enjoy filling it up!
              </i>
            </h6>
          )}

          <h6>
            <strong>Note:</strong>{" "}
            <i>
              Fields with asterisk (<b className="red-text font-bold">*</b>) are
              required.
            </i>
          </h6>
        </MDBCol>
      </MDBRow>
      <hr
        style={{
          border: "1 px solid black",
          width: "100%",
          transform: "scale(1.03)",
        }}
      />
      {isRegistrar ? (
        <>
          <Identify
            setDetails={setDetails}
            data={details}
            setUserData={setUserData}
            isRegistrar={isRegistrar}
            batches={batches}
            openBatch={openBatch}
            setState={setState}
            resetForm={resetForm}
          />;
          <Health 
            setDetails={setDetails} 
            data={details} 
            setUserData={setUserData} 
            handleObjChange={handleObjChange}
          />
          ;
          <Address addressInfo={details} handleObjChange={handleObjChange} />;
          <Parents
            setDetails={setDetails}
            data={details}
            setUserData={setUserData}
          />
          ;
          <Documents
            setDetails={setDetails}
            data={details}
            handleBlockNextBtn={handleBlockNextBtn}
            isRegistrar={isRegistrar}
            isNewStudent={isNewStudent}
          />;
          <Enrollment
            setDetails={setDetails}
            data={details}
            isNewNReject={isNewReject}
            collections={batches}
            setUserData={setUserData}
            handleBlockNextBtn={handleBlockNextBtn}
          />
        </>
      ) : (
        renderSteps()
      )}
    </>
  );
};

export default Body;
