import { MDBBtn, MDBCardBody, MDBCardHeader, MDBCol, MDBIcon, MDBRow } from 'mdbreact'
import React from 'react'

const RejectCard = ({isMale, fullName, student, setResolveIssue, canEnroll, rejected}) => {
  return (
    <>
        <MDBCardHeader className="bg-white">
            <MDBRow>
                <MDBCol>
                    <h5> 
                        Status: 
                        <span className="red-text font-weight-bold ml-2">
                            REJECTED
                        </span>
                    </h5>
                </MDBCol>
            </MDBRow>
        </MDBCardHeader>
        <MDBCardBody>
            <MDBRow>
                <MDBCol md="12">
                    <p className="ml-2" style={{ fontSize: "1.1rem" }}>
                        <strong>
                            Dear {isMale ? "Mr." : "Ms."}{" "}
                            {fullName.fname + " " + fullName.lname}
                        </strong>
                        , {!rejected ? (
                            student.enrolleeData?.registrar?.message
                        ) : (
                            <span>
                                Your old rejected enrollment request wasn't acted upon, but don't worry—enrollment is now open. <br/> 
                                Please settle your old issue: {student.enrolleeData?.registrar?.message}
                            </span>
                        )}
                    </p>
                    
                    {!canEnroll && (
                    <div className={"mt-3 alert alert-warning"}>
                        <MDBIcon icon="info-circle" className="mr-2" />
                        Sorry Currently no open Enrollment
                    </div>
                    )}
                    
                    <MDBBtn
                        color="danger"
                        onClick={() => setResolveIssue(true)}
                        disabled={!canEnroll}
                        size='md'
                    >
                        {rejected ? "RESOLVE ISSUE IN YOUR FORM": "RE ENROLL"} 
                    </MDBBtn>

                </MDBCol>
            </MDBRow>
        </MDBCardBody>
    </>
  )
}

export default RejectCard