import React, { useEffect, useState } from "react";
import { CHANGE_PASSWORD } from "../../../services/redux/slices/auth";
import {
  MDBBtn,
  MDBCol,
  MDBRow,
  MDBTypography,
} from "mdbreact";
import { useDispatch } from "react-redux";
import Swal from "sweetalert2";
import PasswordInput from "../../../components/passwordInput";

function ChangePassword({
  setIsForgot,
  searchFound,
  setBaseEmail,
  setHeaderTitle,
}) {
  const [newPassword, setNewPassword] = useState(""),
    [showWarning, setShowWarning] = useState(false),
    [isLocked, setIsLocked] = useState(true),
    [passwordStatus, setPasswordStatus] = useState(""),
    [isWeak, setIsWeak] = useState(false),
    dispatch = useDispatch();

  useEffect(() => {
    setHeaderTitle("Choose a new password");
  }, [setHeaderTitle]);

  const handleSubmit = (event) => {
    event.preventDefault();
    /* weak password prevent to send */
    if(passwordStatus) {
      setIsWeak(true)
      return
    }


    if (newPassword.length <= 5) return setShowWarning(true);

    Swal.fire({
      title: "Are you sure?",
      text: "Do you want to submit the new password?",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#3085d6",
      cancelButtonColor: "#d33",
      confirmButtonText: "Yes, submit it!",
    }).then((result) => {
      if (result.isConfirmed) {
        dispatch(
          CHANGE_PASSWORD({ data: { _id: searchFound._id, newPassword } })
        );
        Swal.fire({
          title: "Success!",
          text: "Password changed successfully.",
          icon: "success",
          confirmButtonColor: "#3085d6",
          cancelButtonColor: "#d33",
          confirmButtonText: "Proceed to login!",
        }).then((res) => {
          if (res.isConfirmed) {
            setBaseEmail(searchFound.email);
            setIsForgot(false);
            setHeaderTitle("Login");
          }
        });
      }
    });
  };

  return (
    <>
      {showWarning && (
        <MDBTypography
          variant="h2"
          noteColor="danger"
          note
          noteTitle="Warning: "
        >
          Please provide a password that is at least 8 characters long.
        </MDBTypography>
      )}
      {(isWeak && isWeak) && (
        <MDBTypography
          variant="h2"
          noteColor="danger"
          note
          noteTitle="Warning: "
        >
          Please provide a more secure password.
        </MDBTypography>
      )}
      <h5>
        Create a new password that is at least 8 characters long. A strong
        password is combination of letters,numbers,and punctuation marks.
      </h5>
      <form onSubmit={handleSubmit}>
        <div className="isLock">
          <MDBRow>
            <MDBCol>
              <PasswordInput 
                password={newPassword}
                setPassword={setNewPassword}
                isLocked={isLocked}
                setIsLocked={setIsLocked}
                setPasswordStatus={setPasswordStatus}
                label={"New Password"}
              />
            </MDBCol>
          </MDBRow>
        </div>

        <hr />
        <MDBRow>
          <MDBCol md="12" className="d-flex justify-content-end">
            <MDBBtn
              color="light"
              type="button"
              onClick={() => {
                setIsForgot(false);
                setHeaderTitle("Login");
              }}
            >
              Cancel
            </MDBBtn>
            <MDBBtn color="primary" type="submit">
              Continue
            </MDBBtn>
          </MDBCol>
        </MDBRow>
      </form>
    </>
  );
}

export default ChangePassword;
