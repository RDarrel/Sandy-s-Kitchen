import React from "react";
import { MDBCol, MDBRow } from "mdbreact";
import logo from "../../../../../../assets/logo/logo.png";
import matatag from "../../../../../../assets/logo/matatag.png";
import deped from "../../../../../../assets/logo/deped.png";
import "./header.css";
import "../learner.css";
export const Header = ({ batch }) => {
  const _batch = batch.find((bch) => bch.progress === "jhs") || "";
  return (
    <>
      <MDBRow>
        <div className="_container-logo">
          <img
            src={logo}
            alt="Logo"
            style={{ height: "80px", width: "80px" }}
          />
        </div>
        <MDBCol className="text-center">
          <h1
            className="font-weight-bold school-name"
            style={{ marginRight: "5rem", color: "rgb(0, 0, 255)" }}
          >
            Leonor M. Bautista National High School
          </h1>
          <h6 className="font-weight-bold address">
            Brgy.Pias, General Tinio, Nueva Ecija Region III
          </h6>
        </MDBCol>
        <div className="_container-logo-left">
          <img
            src={deped}
            alt="Logo"
            style={{ height: "80px", width: "80px" }}
          />
          <img
            src={matatag}
            alt="Logo"
            style={{ height: "90px", width: "90px" }}
          />
        </div>
      </MDBRow>

      <MDBRow className="m-0">
        <MDBCol className="text-center">
          <h6 className="font-weight-bold m-0">{_batch.sy}</h6>
        </MDBCol>
      </MDBRow>

      <MDBRow className="container-enrollment">
        <MDBCol className="d-flex col-cont d-flex justify-content-center align-items-center">
          <div className=" d-flex justify-content-center ">
            <h2 className="font-weight-bold text-white text-center mt-2 w-100 enrollment">
              BASIC EDUCATION ENROLLMENT FORM
            </h2>
          </div>
        </MDBCol>
      </MDBRow>
    </>
  );
};
