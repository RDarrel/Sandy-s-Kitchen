import { MDBAvatar, MDBBtn, MDBCardBody, MDBCol, MDBRow } from 'mdbreact'
import React from 'react'
import { PresetImage } from '../../../../../../services/utilities'
import { RESET, SETROUTE } from '../../../../../../services/redux/slices/auth'
import { useDispatch } from 'react-redux'
import { useHistory } from "react-router";

const FailCard = ({ student, fullName, auth, grades, picture, openForm, showBtn }) => {
  const history = useHistory();
  const dispatch = useDispatch();

  return (
    <>
      <MDBCardBody>
        <div className="d-flex align-items-center justify-content-center w-100 dropOut-banner-container" style={{position: "absolute",top: "20%"}}>
              <div className="d-flex align-items-center justify-content-center dropOut-banner" 
              style={{textAlign: "center", fontSize: "80px", fontWeight: "bold", color: "red", transform: "rotate(-30deg)", border: "7px solid", padding: "0 20px", backgroundColor: "#d9d9d975", zIndex: "1"}}>
              FAILED
              </div>
        </div>
        <MDBRow className="profile-row">
          <MDBCol md="9" className="mt-4 info-section">
              <div>
              <h5 className="pb-1"><strong>NAME:</strong> {(fullName.fname + " " + fullName.mname + " " + fullName.lname).toUpperCase()}</h5>
              <h5 className="pb-1"><strong>GRADE:</strong> {(student.enrolleeData?.lvl + " " + student.enrolleeData?.section?.name).toUpperCase()}</h5>
              <h5 className="pb-1"><strong>GENERAL AVERAGE:</strong> <b className={`${grades < 75 ? 'red-text' : 'green-text'}`}>{grades}</b></h5>
              </div>
          </MDBCol>
          <MDBCol md="3" className="mt-4 profile-section">
            <h6 className="pb-2"><strong>LRN:</strong> {student.credentials?.LRN.toUpperCase()}</h6>
            <MDBAvatar
            tag="img"
            src={picture}
            onError={(e) => (e.target.src = PresetImage(auth.isMale))}
            alt={`preview-${auth._id}`}
            className="z-depth-1 mb-3 mx-auto rounded student-picture"
            style={{width: "100%"}}
            />
          </MDBCol>
        </MDBRow>
        <MDBRow>
            <MDBCol md="12" className="mt-4 drop-message">
                <h5 className="msg-txt"> <b>
                  We regret to inform you that your grades for the previous term do not meet the required standards for enrollment. We encourage you to review your academic progress and consider seeking additional support to improve your performance.
                <br /><br />If you have any questions or need further assistance, please don't hesitate to reach out to us.
                </b></h5>
            </MDBCol>
        </MDBRow>
        
        <MDBRow>
            <MDBBtn
                color="primary"
                size='md'
                onClick={() => {
                  history.push("/grades");
                  dispatch(SETROUTE("grades"));
                  dispatch(RESET());
                }}
            >
                View grades
            </MDBBtn>

            {showBtn && (
              <MDBBtn
                color="primary"
                size='md'
                onClick={() => openForm(true)}
              >
                Enroll
              </MDBBtn>
            )}
          </MDBRow>
        </MDBCardBody>
    </>
  )
}

export default FailCard