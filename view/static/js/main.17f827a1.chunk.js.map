import { isJpegOrJpgFile } from "../../../../../../services/utilities";

export default function uploadDocuments(auth, documents) {
    return new Promise((resolve, reject) => {
        const generateFileName = (baseName, authEmail) =>
            `${baseName}-${authEmail}.jpg`;

        const processedImages = [];
        let processedCount = 0; // Track the number of processed images

        const resizeAndUpload = (file, key) => {
            const reader = new FileReader();

            reader.onload = (e) => {
                const img = new Image();

                img.onload = function () {
                    let targetWidth, targetHeight;
                    if (key === "studentPicture" || key === "signature") {
                        targetWidth = targetHeight = 600; // 2x2 inches, we need 600x600 pixels
                    } else {
                        targetWidth = this.width;
                        targetHeight = this.height;
                    }

                    const canvas = document.createElement("canvas");
                    const ctx = canvas.getContext("2d");
                    canvas.width = targetWidth;
                    canvas.height = targetHeight;
                    ctx.drawImage(img, 0, 0, targetWidth, targetHeight);
                    canvas.toBlob(function (blob) {
                        const reader = new FileReader();
                        reader.readAsDataURL(blob);
                        reader.onloadend = function () {
                            const base64data = reader.result.split(",")[1];
                            const fileName = generateFileName(key, auth.email);

                            processedImages.push({
                                path: `documents/${auth.email}-${auth._id}`,
                                base64: base64data,
                                name: fileName,
                            });

                            processedCount++; // Increment processed count

                            if (processedCount === Object.keys(documents).length) {
                                resolve(processedImages); 
                            }
                        };
                        reader.onerror = () => reject(new Error("Failed to read the resized image."));
                    }, "image/jpeg");
                };

                img.onerror = () => reject(new Error(`Failed to load the ${key}.`));
                img.src = e.target.result;
            };

            reader.onerror = () => reject(new Error(`Failed to read the ${key}.`));
            reader.readAsDataURL(file);
        };

        Object.entries(documents).forEach(([key, file]) => {
            if (typeof file === "string") {
                fetch(file)
                    .then(response => response.blob())
                    .then(blob => {
                        resizeAndUpload(blob, key);
                    })
                    .catch(error => reject(new Error(`Failed to fetch the image from URL: ${error.message}`)));
            } else {
                if (file && isJpegOrJpgFile(file)) {
                    resizeAndUpload(file, key);
                } else {
                    reject(new Error(`Invalid file format for ${key}.`));
                }
            }
        });
    });
}
