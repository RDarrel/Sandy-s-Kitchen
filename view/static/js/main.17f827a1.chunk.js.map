import { MDBCol, MDBInput, MDBRow } from 'mdbreact'
import React, { useEffect, useState } from 'react'

import "../learner.css";
const Health = ({ setDetails, data, setUserData, handleObjChange}) => {
  const [disability, setDisability] = useState(data.healthStatistics?.hasDisability || false)
  const [disabilities, setDisabilities] = useState(data.healthStatistics?.disabilities || [])

  const handleHasDisablity = (obj, key, value) => {
    let _obj = { ...data[obj], [key]: value, disabilities: [] }

    if(!value){
      _obj = { ..._obj, disabilities: [] }
      setDisabilities([]);
    }
    setDetails({...data, [obj]: _obj })
    setUserData((prev) => ({ ...prev, [obj]: _obj }))
    setDisability(value);
  };

  const handleDisabilities = (value, checked) => {
    let updatedDisabilities = [...disabilities];
  
    if (checked && disability) {
      if (
        (value === "blind" && disabilities.includes("low vision")) ||
        (value === "low vision" && disabilities.includes("blind"))
      ) {
        updatedDisabilities = disabilities.filter(
          (item) => item !== (value === "blind" ? "low vision" : "blind")
        );
      } else {
        updatedDisabilities.push(value);
      }
    } else {
      updatedDisabilities = disabilities.filter((item) => item !== value);
    }

    const updatedHealthStatistics = { ...data.healthStatistics, disabilities: updatedDisabilities };

    setDetails({ ...data, healthStatistics: updatedHealthStatistics });
    setDisabilities(updatedDisabilities);
    setUserData((prev) => ({
      ...prev,
      healthStatistics: updatedHealthStatistics,
    }));
  };

  useEffect(() => {
    if(data.healthStatistics?.hasDisability) {
      const { hasDisability, disabilities } = data.healthStatistics;
      setDisability(hasDisability || false);
      setDisabilities(disabilities || []);
    }else { 
      setDisability(false);
      setDisabilities([]);
    }
  }, [data.healthStatistics]);

  return (
    <>
      <MDBRow style={{ backgroundColor: "#0000FF" }}>
        <MDBCol>
          <h5 className="font-weight-bold text-white mt-2 label mb-2 ml-5 section-title">
            II. Health Survey
          </h5>
        </MDBCol>
      </MDBRow>

      <MDBRow className="ml-4 mt-4">
        <MDBCol>
          <h6>
            <span className="red-text">*</span>
            <strong>Is the child Learner with Disability?</strong>
          </h6>
        </MDBCol>
      </MDBRow>
      <MDBRow className="ml-4">
        <MDBCol className="p-0" md="2">
          <MDBInput
            label="Yes"
            type="checkbox"
            name="hasDisability"
            checked={disability}
            onChange={(e) => handleHasDisablity("healthStatistics", e.target.name, true)}
            id="wDisability"
          />
        </MDBCol>
        <MDBCol className="p-0" md="10">
          <MDBInput
            label="No"
            type="checkbox"
            name="hasDisability"
            checked={!disability}
            onChange={(e) => handleHasDisablity("healthStatistics", e.target.name, false)}
            id="nDisability"
          />
        </MDBCol>
      </MDBRow>

      <MDBRow className="ml-4 mt-4">
        <MDBCol>
          <h6>
            <strong>If Yes, specify the type of disability:</strong>
          </h6>
        </MDBCol>
      </MDBRow>

      <MDBRow>
        <MDBCol md="6">
          <MDBRow className="m-4">
            <MDBCol>
              <h6>
                <strong>Visual Impairment</strong>
              </h6>
            </MDBCol>
          </MDBRow>
          <MDBRow className="ml-4">
            <MDBCol md="4">
              <MDBInput
                label="a. Blind"
                type="checkbox"
                value="blind"
                name="visual"
                checked={
                  disabilities.includes("blind") &&
                  !disabilities.includes("low vision")
                }
                onChange={(e) =>
                  handleDisabilities(e.target.value, e.target.checked)
                }
                id="blind"
              />
            </MDBCol>

            <MDBCol md="8">
              <MDBInput
                label="a. Low vision"
                type="checkbox"
                value="low vision"
                name="visual"
                checked={
                  disabilities.includes("low vision") &&
                  !disabilities.includes("blind")
                }
                onChange={(e) =>
                  handleDisabilities(e.target.value, e.target.checked)
                }
                id="vision"
              />
            </MDBCol>
          </MDBRow>
        </MDBCol>

        <MDBCol md="6">
          <MDBRow className="m-4">
            <MDBCol className="p-0">
              <h6>
                <strong>Special Health Problem/Chronic Disease</strong>
              </h6>
            </MDBCol>
          </MDBRow>
          <MDBRow className="ml-4">
            <MDBCol>
              <MDBInput
                label="a. Cancer"
                type="checkbox"
                value="cancer"
                name="diceased"
                checked={disabilities.includes("cancer")}
                onChange={(e) =>
                  handleDisabilities(e.target.value, e.target.checked)
                }
                id="cancer"
              />
            </MDBCol>
          </MDBRow>
        </MDBCol>
      </MDBRow>

      <MDBRow className="m-4">
        <MDBCol className="p-0" md="3">
          <MDBInput
            label="Hearing Impairment"
            type="checkbox"
            value="hearing impairment"
            name="diceased"
            checked={disabilities.includes("hearing impairment")}
            onChange={(e) =>
              handleDisabilities(e.target.value, e.target.checked)
            }
            id="hearing"
          />
        </MDBCol>

        <MDBCol className="p-0" md="3">
          <MDBInput
            label="Learning Disability"
            type="checkbox"
            value="learning disability"
            name="diceased"
            checked={disabilities.includes("learning disability")}
            onChange={(e) =>
              handleDisabilities(e.target.value, e.target.checked)
            }
            id="learning"
          />
        </MDBCol>

        <MDBCol className="p-0" md="3">
          <MDBInput
            label="Intelectual Disability"
            type="checkbox"
            value="intelectual disability"
            name="diceased"
            checked={disabilities.includes("intelectual disability")}
            onChange={(e) =>
              handleDisabilities(e.target.value, e.target.checked)
            }
            id="intelectual"
          />
        </MDBCol>

        <MDBCol className="p-0" md="3">
          <MDBInput
            label="Autism Spectrum Disorder"
            type="checkbox"
            value="autism spectrum disorder"
            name="diceased"
            checked={disabilities.includes("autism spectrum disorder")}
            onChange={(e) =>
              handleDisabilities(e.target.value, e.target.checked)
            }
            id="autism"
          />
        </MDBCol>
      </MDBRow>

      <MDBRow className="m-4">
        <MDBCol className="p-0" md="3">
          <MDBInput
            label="Emotional-Behavioral Disorder"
            type="checkbox"
            value="emotional-behavioral disorder"
            name="diceased"
            checked={disabilities.includes("emotional-behavioral disorder")}
            onChange={(e) =>
              handleDisabilities(e.target.value, e.target.checked)
            }
            id="emotional"
          />
        </MDBCol>

        <MDBCol className="p-0" md="3">
          <MDBInput
            label="Orthopedic/ Physical Handicap"
            type="checkbox"
            value="orthopedic/physical handicap"
            name="diceased"
            checked={disabilities.includes("orthopedic/physical handicap")}
            onChange={(e) =>
              handleDisabilities(e.target.value, e.target.checked)
            }
            id="orthopedic"
          />
        </MDBCol>

        <MDBCol className="p-0" md="3">
          <MDBInput
            label="Speech/ Language Disoder"
            type="checkbox"
            value="speech/language disoder"
            name="diceased"
            checked={disabilities.includes("speech/language disoder")}
            onChange={(e) =>
              handleDisabilities(e.target.value, e.target.checked)
            }
            id="speech"
          />
        </MDBCol>

        <MDBCol className="p-0" md="3">
          <MDBInput
            label="Celebral Paisy"
            type="checkbox"
            value="celebral paisy"
            name="diceased"
            checked={disabilities.includes("celebral paisy")}
            onChange={(e) =>
              handleDisabilities(e.target.value, e.target.checked)
            }
            id="celebral"
          />
        </MDBCol>
      </MDBRow>
      <MDBRow className="m-4">
        <MDBCol className="p-0" md="3">
          <MDBInput
            label="Multiple Disorder"
            type="checkbox"
            value="multiple disorder"
            name="diceased"
            checked={disabilities.includes("multiple disorder")}
            onChange={(e) =>
              handleDisabilities(e.target.value, e.target.checked)
            }
            id="multiple"
          />
        </MDBCol>
      </MDBRow>

      <MDBRow style={{ backgroundColor: "#0000FF" }}>
        <MDBCol>
          <h5 className="font-weight-bold text-white mt-2 label mb-2 ml-5 section-title">
            II.I Physical Statistics
          </h5>
        </MDBCol>
      </MDBRow>

      <MDBRow className="m-4">
        <MDBCol className="pt-0 pb-0 pl-0 pr-2" sm="6" lg="4">
          <h6 className="mt-4">
            <strong>
              {" "}
              <span className="red-text">*</span>Height(cm)
            </strong>
          </h6>
          <input
            type="text"
            placeholder="Height"
            value={data.healthStatistics?.height || ""}
            name="height"
            className="form-control lrn"
            onChange={(e) =>
              handleObjChange("healthStatistics", e.target.name, e.target.value)
            }
            required
          />
        </MDBCol>
        <MDBCol className="pt-0 pb-0 pl-0 pr-2" sm="6" lg="4">
          <h6 className="mt-4">
            <strong>
              {" "}
              <span className="red-text">*</span>Weight(kg)
            </strong>
          </h6>
          <input
            type="text"
            placeholder="Weight"
            value={data.healthStatistics?.weight || ""} 
            name="weight"
            className="form-control lrn"
            onChange={(e) =>
              handleObjChange("healthStatistics", e.target.name, e.target.value)
            }
            required
          />
        </MDBCol>
        <MDBCol className="pt-0 pb-0 pl-0 pr-2" sm="6" lg="4">
          <h6 className="mt-4">
            <strong>Blood type</strong>
          </h6>
          <input
            type="text"
            placeholder="Blood type"
            value={data.healthStatistics?.bloodType || ""}
            name="bloodType"
            className="form-control lrn"
            onChange={(e) =>
              handleObjChange("healthStatistics", e.target.name, e.target.value)
            }
          />
        </MDBCol>
      </MDBRow>
    </>
  );
};

export default Health;
