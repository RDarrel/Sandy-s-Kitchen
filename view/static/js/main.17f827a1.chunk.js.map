import React, { useState } from "react";
import { MDBRow, MDBCol, MDBInput } from "mdbreact";

import "../learner.css";

import AddressSelect from "../../../../../../components/addressSelect";

const Address = ({handleObjChange, addressInfo}) => {
  const [sameAddress, setSameAddress] = useState(false);

  const handleSameAddress = (checked) => {
    if (checked) {
      setSameAddress(true);
      handleObjChange("address", "permanent", addressInfo.address.current);
      return;
    }
    setSameAddress(false);
  };

  return (
    <>
      <MDBRow style={{ backgroundColor: "#0000FF" }}>
        <MDBCol>
          <h5 className="font-weight-bold text-white mt-2 label mb-2 ml-5 section-title">
            I.I. ADDRESS INFORMATION
          </h5>
        </MDBCol>
      </MDBRow>

      <MDBRow className="p-2 mt-4 mr-4 ml-4">
        <MDBCol>
          <AddressSelect
            label="Current address"
            address={addressInfo.address?.current}
            handleChange={(_, value) =>
              handleObjChange("address", "current", value)
            }
          />
        </MDBCol>
      </MDBRow>
      <MDBRow>
        <MDBCol>
          <MDBInput
            className="m-0"
            label="Same as my current address"
            iconClass="black-text"
            labelClass="black-text"
            type="checkbox"
            checked={sameAddress}
            onChange={(e) => handleSameAddress(e.target.checked)}
            id="isSame"
          />
        </MDBCol>
      </MDBRow>
      <MDBRow className="p-2 mr-4 ml-4">
        <MDBCol>
          <AddressSelect
            label="Permanent address"
            address={addressInfo.address?.permanent}
            handleChange={(_, value) =>
              handleObjChange("address", "permanent", value)
            }
          />
        </MDBCol>
      </MDBRow>
    </>
  );
};

export default Address;
