import React, { useEffect, useState } from "react";
import { MDBBtn, MDBCard, MDBCardBody, MDBCol, MDBRow } from "mdbreact";
import { useDispatch } from "react-redux";
import { SAVE } from "../../../../../services/redux/slices/student/credentials";

import Body from "./body";
import { Header } from "./headers";
import Steps from "../../../../../components/steps";
import fetchDocumentFile from "./imageTools/fetchFiles";
import uploadDocuments from "./imageTools/uploadDocs";
import useLocalStorage from "../../../../../services/utilities/useLocalStorage/localStorage";

import { useToasts } from "react-toast-notifications";
import Swal from "sweetalert2";
import resetUserDetails from "./identify/resetForm";

const _address = {
  current: {
    region: "REGION III (CENTRAL LUZON)",
    province: "NUEVA ECIJA",
    city: "GENERAL TINIO (PAPAYA)",
    barangay: "Pias",
    zip: "",
    street: "",
    hn: "",
  },
  permanent: {
    region: "REGION III (CENTRAL LUZON)",
    province: "NUEVA ECIJA",
    city: "GENERAL TINIO (PAPAYA)",
    barangay: "Pias",
    zip: "",
    street: "",
    hn: "",
  },
};

const _parentInfo = {
  fullName: {
    fname: "",
    mname: "",
    lname: "",
  },
  mobile: "",
};

const _details = {
  parents: {
    mother: _parentInfo,
    father: _parentInfo,
    guardian: _parentInfo,
  },

  fullName: {
    fname: "",
    mname: "",
    lname: "",
    suffix: "",
  },
  email: "",
  dob: "",
  birthplace: "",
  isMale: true,
  mobile: "",
  address: _address,

  healthStatistics: {
    height: "",
    weight: "",
    bloodType: "",
    hasDisability: false,
    disabilities: [],
  },

  progress: "jhs",
  lvl: 7,
  specialization: "",
  strand: "",

  studentPicture: "",
  signature: "",
  PSA: "",
  card: "",
  clearance: "",
  LRN: "",

  lastSchool: {
    name: "",
    address: ""
  },

  hasStudentPicture: false,
  hasSignature: false,
  hasPSA: false,
  hasCard: false,
  hasClearance: false,
  hasLRN: false,
};

const allSteps = [
  { icon: "user", step: 1, done: "" },
  { icon: "home", step: 2, done: "" },
  { icon: "heart", step: 3, done: "" },
  { icon: "users", step: 4, done: "" },
  { icon: "image", step: 5, done: "" },
  { icon: "keyboard", step: 6, done: "" },
];

export default function EnrollmentForm({
  resetForm = false,
  auth,
  token,
  batches /* all batch */,
  back = false,
  setBack = () => {},
  status /* batch status */,
  isNewReject = false,
  isNewStudent = false,
  studentData = {} /* object of student */,
  batch /* active or open batch */,
  enrolleeID,
  isDrop = false,
  remarks = 0,
  isRegistrar = false,
  setState = () => {},
}) {
  const [studentDetails, setStudentDetails] = useState(_details);
  const [steps, setSteps] = useState(1);
  const [errorMsg, setErrorMessage] = useState("");
  const [openProgress, setOpenProgress] = useState({
    jhs: false,
    shs: false,
  });
  const [disableSubmitBtn, setDisableSubmitBtn] = useState(false);
  const [isEnrolled, setisEnrolled] = useState(false);
  const [warning, setWarning] = useState(false);
  const [userData, setUserData] = useLocalStorage("data", _details);
  const [_lastStep, _setLastStep] = useLocalStorage("lastStep", 1);

  const { addToast } = useToasts();
  const dispatch = useDispatch();

  useEffect(() => {
    if (resetForm) {
      setStudentDetails(resetUserDetails())
    }
  }, [resetForm]);

  //submit form
  const handleSubmit = (e) => {
    e.preventDefault();

    if (
      studentDetails.transferee &&
      !studentDetails?.birthCertificate &&
      !studentDetails?.form137 &&
      !studentDetails?.goodMoral
    ) {
      setErrorMessage(
        "The required documents for the transferee student are missing!"
      );
      return;
    }

    if ((isValid(steps) && steps === allSteps.length) || isRegistrar) {
      Swal.fire({
        focusDeny: true,
        icon: "question",
        title: `Are you sure you want to submit this form?`,
        text: "This action is irreversible.",
        confirmButtonText: "Proceed",
        confirmButtonColor: "#3B71CA",
        showDenyButton: true,
        denyButtonText: '<span class="text-dark">Cancel</span>',
        denyButtonColor: "#fff",
      }).then(async (res) => {
        if (res.isConfirmed) {
          try {
            const {
              parents,
              studentPicture,
              card,
              PSA,
              signature,
              clearance,
              LRN,
              healthStatistics,
              lastSchool,
              ...data
            } = studentDetails;

            const student_id = isRegistrar
              ? studentDetails?.studentId
              : auth._id;

            const enrolleeData = {
              ...data,
              student: student_id,
              enrolleeId: enrolleeID,
              status: data.enrollmentStatus ? data.enrollmentStatus : "PENDING",
              ...(data.returnee && { returnee: true }),
              ...(data.transferee && { transferee: true }),
              wasApproved: isRegistrar,
            };
            let documentsData = await uploadDocuments(
              { _id: "", email: studentDetails.email },
              {
                studentPicture,
                signature,
                PSA,
                card,
                ...(studentDetails?.birthCertificate ? { birthCertificate : studentDetails.birthCertificate } : {}),
                ...(studentDetails?.form137 ? { form137: studentDetails.form137 } : {}),
                ...(studentDetails.goodMoral ? { goodMoral: studentDetails.goodMoral } : {}),
                ...(clearance ? { clearance } : {}),
              }
            );

            const files = {
              hasStudentPicture: studentPicture ? true : false,
              hasSignature: signature ? true : false,
              hasPSA: PSA ? true : false,
              hasCard: card ? true : false,
              hasClearance: clearance ? true : false,
              hasBirthCertificate: studentDetails.birthCertificate
                ? true
                : false,
              hasForm137: studentDetails.form137 ? true : false,
              hasGoodMoral: studentDetails.goodMoral ? true : false,
              images: [...documentsData],
            };

            console.log(lastSchool);
            
            dispatch(
              SAVE({
                data: {
                  credentials: {
                    ...parents,
                    student: student_id,
                    files,
                    healthStatistics: studentDetails.healthStatistics,
                    progress: studentDetails.progress,
                    LRN,
                    lastSchool: lastSchool
                  },
                  enrolleeInfo: { ...enrolleeData },
                },
                token,
              })
            );
            _setLastStep(1);
          } catch (error) {
            addToast("An error occurred during form submission", {
              appearance: "error",
            });
          }
        } else {
          return Swal.fire({
            title: "Changes are not Saved!",
            icon: "warning",
            showConfirmButton: false,
            timer: 2500,
            timerProgressBar: true,
          }).then(() => false);
        }
      });
    }
  };

  useEffect(() => {
    let swalPromise;

    if (status === "INACTIVE") {
      swalPromise = Swal.fire({
        icon: "info",
        title: "Be Patient",
        text: "Sorry for the inconvenience, but the enrollment is temporarily closed.",
        showConfirmButton: false,
        showCancelButton: false,
        allowOutsideClick: false,
        allowEscapeKey: false,
        allowEnterKey: false,
      });
    }
    return () => {
      if (swalPromise) {
        swalPromise.close();
      }
    };
  }, [status]);

  const handleObjChange = (obj, key, value) => {
    const _obj = { ...studentDetails[obj] };
    _obj[key] = value;
    setStudentDetails({ ...studentDetails, [obj]: _obj });
    setUserData({ ...studentDetails, [obj]: _obj });
  };

  const handleNext = () => {
    if (isValid(steps + 1) && steps < allSteps.length) {
      setSteps((prev) => prev + 1);
      console.log("dito sim");
    _setLastStep(steps + 1);
    }
  };

  const isValid = (targetStep) => {
    let _isValid = false;
    let customError = ""
    for (let step = 1; step <= targetStep; step++) {
      switch (step) {
        case 2:
          _isValid =
            validateFormObj(
              ["suffix", "mname", "birthplace"],
              studentDetails.fullName
            ) &&
            validateForm(studentDetails.LRN) &&
            studentDetails.LRN.length === 12;
          allSteps[0].done = _isValid;

          if(studentDetails.LRN.length !== 12) {
            customError = "Please provide your exact LRN"
          }
          break;

        case 3:
          _isValid = true;
          allSteps[1].done = _isValid;
          break;

        case 4:
          let validHealth = true,
            validStats = false;

          if (studentDetails.healthStatistics?.hasDisability) {
            validHealth =
              studentDetails.healthStatistics?.disabilities.length !== 0;
          }

          validStats =
            studentDetails.healthStatistics?.height !== "" &&
            studentDetails.healthStatistics?.height !== undefined &&
            studentDetails.healthStatistics?.weight !== "" &&
            studentDetails.healthStatistics?.weight !== undefined;

          _isValid = validHealth && validStats;
          allSteps[2].done = _isValid;
          break;

        case 5:
          if(studentDetails.parents?.guardian === undefined) {
            _isValid = false
          }else {
            _isValid = validateFormObj(
              ["mname"],
              studentDetails.parents?.guardian
            );
          }

          allSteps[3].done = _isValid;
          break;

        case 6:
          _isValid =
            studentDetails.studentPicture !== "" &&
            studentDetails.signature !== "" &&
            studentDetails.PSA !== "" &&
            studentDetails.card !== "";

          if (!isNewStudent && studentDetails.lvl > 7) {
            _isValid =
              studentDetails.clearance !== "" &&
              studentDetails.clearance !== null;
          }

          allSteps[4].done = _isValid;
          break;

        case 7:
          _isValid =
            validateForm(studentDetails.progress) &&
            studentDetails.lvl !== null;
          if (studentDetails.progress === "shs") {
            _isValid =
              validateForm(studentDetails.strand) &&
              studentDetails.specialization !== null;
          }
          allSteps[5].done = _isValid;
          break;

        default:
          _isValid = true;
          break;
      }

      if (!_isValid) {
        setErrorMessage(
          customError !== "" ? customError : "Oops! It seems you missed some required fields. Please fill them in."
        );
        setWarning(true);
      } else {
        setWarning(false);
      }
    }
    return _isValid;
  };

  useEffect(() => {
    if (errorMsg) {
      setTimeout(() => {
        setErrorMessage("");
      }, 2000);
    }
  }, [errorMsg]);

  const validateForm = (...fields) => {
    return fields.every((field) => field && field.trim() !== "");
  };

  const validateFormObj = (fieldsToSkip = [], ...objects) => {
    const checkProperties = (obj) => {
      for (const key in obj) {
        if (fieldsToSkip.includes(key)) {
          continue;
        }

        const value = obj[key];
        if (
          typeof value === "object" &&
          value !== null &&
          !Array.isArray(value)
        ) {
          if (!checkProperties(value)) return false;
        } else {
          if (typeof value === "string" && !value.trim()) {
            return false;
          } else if (value === null || value === undefined) {
            return false;
          }
        }
      }
      return true;
    };

    for (const obj of objects) {
      if (!checkProperties(obj)) return false;
    }

    return true;
  };

  const handlePrev = () => {
    if (steps > 1) {
      setSteps((prev) => prev - 1);
      _setLastStep((prev) => parseInt(prev) - 1);
    }
  };

  const setStudent = async (isMountedRef) => {
    const _email = isRegistrar ? studentData.email : auth.email;
    const _studentId = isRegistrar ? studentData.studentId : auth._id;

    const studentPictureFile = studentData.credentials?.files?.hasStudentPicture
      ? await fetchDocumentFile("studentPicture", _email, _studentId)
      : null;
    const signatureFile = studentData.credentials?.files?.hasSignature
      ? await fetchDocumentFile("signature", _email, _studentId)
      : null;
    const PSAFile = studentData.credentials?.files?.hasPSA
      ? await fetchDocumentFile("PSA", _email, _studentId)
      : null;
    const cardFile = studentData.credentials?.files?.hasCard
      ? await fetchDocumentFile("card", _email, _studentId)
      : null;

    const _hasClearance = !!batch.find(
      (_batch) => _batch._id === studentData?.enrolleeData?.batch?._id
    );

    const clearanceFile = _hasClearance
      ? await fetchDocumentFile("clearance", _email, _studentId)
      : null;

    if (isMountedRef.current) {
      setStudentDetails((prev) => ({
        ...prev,
        parents: {
          ...studentDetails.parents,
          father: studentData.credentials?.father,
          mother: studentData.credentials?.mother,
          guardian: studentData.credentials?.guardian,
        },

        fullName: {
          ...(studentData?.fullName || studentData?.student?.fullName),
        },

        isMale: studentData.isMale,
        dob: studentData.dob,
        birthplace: studentData.birthplace,
        mobile: studentData.mobile,

        address: { ...studentData.address },

        hasStudentPicture: studentData.credentials?.files?.hasStudentPicture,
        hasSignature: studentData.credentials?.files?.hasSignature,
        hasPSA: studentData.credentials?.files?.hasPSA,
        hasCard: studentData.credentials?.files?.hasCard,
        hasClearance: _hasClearance,

        studentPicture: studentPictureFile,
        signature: signatureFile,
        PSA: PSAFile,
        card: cardFile,
        clearance: clearanceFile,

        hasDisability: studentData.credentials?.hasDisability,
        disabilities: studentData.credentials?.disabilities,

        lvl:
          studentData.enrolleeData?.status === "APPROVED" &&
          studentData.enrolleeData?.batch?.semester !== "1st" &&
          !isDrop &&
          remarks >= 75
            ? studentData.enrolleeData?.lvl + 1
            : studentData.enrolleeData?.lvl,
        progress:
          studentData.enrolleeData?.status === "APPROVED" &&
          remarks >= 75 &&
          !isDrop
            ? "shs"
            : studentData.enrolleeData?.progress,

        specialization: studentData.enrolleeData?.specialization,
        strand: studentData.enrolleeData?.strand,

        enrollmentStatus: studentData.enrolleeData?.status,
        LRN: prev.LRN || studentData.credentials?.LRN,
        transferee: isNewReject ? studentData.enrolleeData.transferee : false,
        healthStatistics: { ...studentData.credentials?.healthStatistics },
        email: isRegistrar ? studentData.email : auth.email,
        studentId: isRegistrar ? studentData.studentId : auth._id,
        isPassedInExam: studentData.isPassedInExam,
      }));
    }
  };

  useEffect(() => {
    const isMountedRef = { current: true };
    if (studentData.credentials) {
      console.log("changed here");
      /* if student has credentials */
      setStudent(isMountedRef);

      allSteps[1].done = true;
      allSteps[3].done = true;
      allSteps[4].done = true;
    } else if (localStorage.getItem("data") && !isRegistrar) {
      console.log("changed here");
      /* if dont have credentials but already fill up the form and back */
      if (_lastStep) {
        setSteps(_lastStep);
      }

      setStudentDetails((prev) => ({
          ...prev,
          ...userData,
        LRN: userData.LRN,
        fullName: { ...studentData.fullName },
        email: isRegistrar ? studentData.email : auth.email,
        isMale: studentData.isMale,
        dob: studentData.dob,
        birthplace: studentData.birthplace,
        mobile: studentData.mobile,
        isPassedInExam: studentData.isPassedInExam,
        address: { ...studentData.address },

        lvl: !studentData.enrolleeData?.lvl
          ? 7
          : studentData.enrolleeData?.status === "APPROVED" &&
            studentData.enrolleeData?.batch?.semester !== "1st" &&
            !isDrop &&
            remarks >= 75
          ? studentData.enrolleeData?.lvl + 1
          : studentData.enrolleeData?.lvl,
        progress: !studentData.enrolleeData?.status
          ? "jhs"
          : studentData.enrolleeData?.status === "APPROVED" &&
            remarks >= 75 &&
            !isDrop
          ? "shs"
          : studentData.enrolleeData?.progress,
      }));
    } else if (Object.keys(studentData).length > 0) {
      console.log("changed here");
      /* if no credentials */
      setStudentDetails((prevStudentDetails) => ({
        ...prevStudentDetails,
        LRN: studentData.LRN || "",
        fullName: { ...studentData.fullName },
        email: isRegistrar ? studentData.email : auth.email,
        isMale: studentData.isMale,
        dob: studentData.dob,
        birthplace: studentData.birthplace,
        mobile: studentData.mobile,
        isPassedInExam: studentData.isPassedInExam,
        address: { ...studentData.address },

        lvl: !studentData.enrolleeData?.lvl
          ? 7
          : studentData.enrolleeData?.status === "APPROVED" &&
            studentData.enrolleeData?.batch?.semester !== "1st" &&
            !isDrop &&
            remarks >= 75
          ? studentData.enrolleeData?.lvl + 1
          : studentData.enrolleeData?.lvl,
        progress: !studentData.enrolleeData?.status
          ? "jhs"
          : studentData.enrolleeData?.status === "APPROVED" &&
            remarks >= 75 &&
            !isDrop
          ? "shs"
          : studentData.enrolleeData?.progress,
      }));
    }

    return () => {
      isMountedRef.current = false;
    };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [isNewReject, isRegistrar, isDrop, remarks, studentData]);

  /* for registrar to set data every search */
  useEffect(() => {
    let isMounted = true;
    if (isRegistrar && isMounted) {
      setStudent(isMounted);
    }

    return () => {
      isMounted = false;
    };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [studentData, isRegistrar]);

  useEffect(() => {
    if (studentData?.batch) {
      const { _id } = studentData?.batch;
      const _isEnrolled = !!batch.find((_batch) => _batch._id === _id);
      setisEnrolled(_isEnrolled);
    } else {
      setisEnrolled(false);
    }
  }, [batch, studentData.batch]);

  useEffect(() => {
    if (batch) {
      batch.forEach((active) => {
        if (active.progress === "jhs") {
          setOpenProgress((prev) => ({ ...prev, jhs: true }));
        } else if (active.progress === "shs") {
          setOpenProgress((prev) => ({ ...prev, shs: true }));
        }
      });
    }
  }, [batch]);

  const studentLevel = studentData?.enrolleeData?.lvl;
  useEffect(() => {
    if (studentLevel === 10) {
      batch.forEach((active) => {
        if (active.progress === "shs" && active.semester === "2nd") {
          setDisableSubmitBtn(true);
          setErrorMessage(
            "Sorry, there are no open batches for Senior High School."
          );
        }
      });
    } else if (studentDetails.progress === "jhs" && !openProgress.jhs) {
      setErrorMessage(
        "Sorry, there are no open batches for Junior High School."
      );
      setDisableSubmitBtn(true);
    } else if (studentDetails.progress === "shs" && !openProgress.shs) {
      setErrorMessage(
        "Sorry, there are no open batches for Senior High School."
      );
      setDisableSubmitBtn(true);
    } else if (
      !isNewStudent &&
      studentDetails.lvl > 7 &&
      studentDetails.clearance === ""
    ) {
      setErrorMessage(
        "Please upload your clearance; it is necessary to proceed with enrollment."
      );
      setDisableSubmitBtn(true);
    } else if (isEnrolled) {
      setDisableSubmitBtn(true);
    } else {
      setDisableSubmitBtn(false);
    }

    setErrorMessage("");
    return () => setDisableSubmitBtn(false);
  }, [
    isEnrolled,
    studentDetails.progress,
    openProgress.jhs,
    openProgress.shs,
    batch,
    studentLevel,
    isNewStudent,
    studentDetails.clearance,
    studentDetails.lvl,
  ]);

  const blockNextBtn = (val) => {
    setDisableSubmitBtn(val);
  };

  return (
    <>
      {!isRegistrar && (
        <MDBCard className="mb-4">
          <MDBCardBody style={{ padding: ".6rem" }}>
            <Steps
              activeStep={steps}
              _steps={allSteps}
              _onClick={(step) => {
                if (isValid(step)) setSteps(step);
              }}
              exclamation={warning}
            />
          </MDBCardBody>
        </MDBCard>
      )}
      <MDBCard>
        <MDBCardBody style={{ padding: "15px" }}>
          <form onSubmit={handleSubmit}>
            {steps === 1 && <Header batch={batch} />}

            <Body
              batches={batches}
              openBatch={batch}
              setDetails={setStudentDetails}
              details={studentDetails}
              _doneSteps={allSteps}
              stepCount={steps}
              isNewReject={isNewReject}
              setUserData={setUserData}
              handleBlockNextBtn={blockNextBtn}
              isRegistrar={isRegistrar}
              handleObjChange={handleObjChange}
              setState={setState}
              resetForm={resetForm}
              isNewStudent={isNewStudent}
            />

            {errorMsg && (
              <div className={"mt-3 alert alert-warning text-center"}>
                {errorMsg}
              </div>
            )}
            <MDBRow className="mt-3 d-flex">
              {back && steps === 1 && (
                <MDBCol className="d-flex justify-content-start">
                  <MDBBtn color="danger" size="md" onClick={setBack}>
                    Close
                  </MDBBtn>
                </MDBCol>
              )}

              {steps > 1 && (
                <MDBCol className="d-flex justify-content-start">
                  <MDBBtn color="light" size="md" onClick={handlePrev}>
                    Prev...
                  </MDBBtn>
                </MDBCol>
              )}

              {(steps === allSteps.length || isRegistrar) && (
                <MDBCol className="d-flex justify-content-end">
                  <MDBBtn
                    color="success"
                    size="md"
                    type="submit"
                    disabled={disableSubmitBtn}
                  >
                    Submit
                  </MDBBtn>
                </MDBCol>
              )}

              {steps !== allSteps.length && !isRegistrar && (
                <MDBCol className="d-flex justify-content-end">
                  <MDBBtn
                    color="primary"
                    size="md"
                    onClick={handleNext}
                    disabled={disableSubmitBtn}
                  >
                    Next
                  </MDBBtn>
                </MDBCol>
              )}
            </MDBRow>
          </form>
        </MDBCardBody>
      </MDBCard>
    </>
  );
}
