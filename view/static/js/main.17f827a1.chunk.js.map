import { MDBCardBody, MDBCardHeader, MDBCol, MDBRow } from 'mdbreact'
import React from 'react'

const PendingCard = ({isMale, fullName}) => {
  return (
    <>
        <MDBCardHeader className="bg-white">
            <MDBRow>
                <MDBCol>
                    <h5> 
                        Status: 
                        <span className="blue-text font-weight-bold ml-2">
                            PENDING
                        </span>
                    </h5>
                </MDBCol>
            </MDBRow>
        </MDBCardHeader>
        <MDBCardBody>
            <MDBRow>
                <MDBCol>
                    <p style={{ fontSize: "1.1rem" }}>
                        <strong>
                            Dear {isMale ? "Mr." : "Ms."}{" "}
                            {fullName.fname + " " + fullName.lname}
                        </strong>
                        , We hope this message finds you well. We want to inform you
                        that your enrollment status is currently pending. Our team
                        is diligently reviewing the information you provided, and we
                        appreciate your patience during this process.
                        <br /> 
                        <br />
                        Thank you for choosing{" "}
                        <strong>Leonor M. Bautista National High School</strong>.
                        We're excited to see you in class for this school year.
                    </p>
                </MDBCol>
            </MDBRow>
        </MDBCardBody>
    </>
  )
}

export default PendingCard