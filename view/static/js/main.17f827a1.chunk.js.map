import { MDBCardBody, MDBCol, MDBRow } from 'mdbreact'
import React from 'react'
import graduateImg from "../../../../../../assets/graduates.jpg"

const GraduateCard = ({isMale, fullName}) => {
  return (
    <>
        <MDBCardBody>
            <MDBRow>
                <MDBCol>
                    <img src={graduateImg} alt="graduateImg" />
                </MDBCol>
            </MDBRow>
            <MDBRow>
                <MDBCol>
                    <p style={{ fontSize: "1.1rem" }}>
                        <strong>
                            Dear {isMale ? "Mr." : "Ms."}{" "}
                            {fullName.fname + " " + fullName.lname}{", "}
                        </strong>
                        Our records show that you have successfully graduated from our institution. 
                        As a graduate, you are no longer eligible for enrollment in our system. 
                        Congratulations on your accomplishment! 
                        <br />
                        Wishing you all the best in your future endeavors!
                    </p>


                </MDBCol>
            </MDBRow>
        </MDBCardBody>
    </>
  )
}

export default GraduateCard