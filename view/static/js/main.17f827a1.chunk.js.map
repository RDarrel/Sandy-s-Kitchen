import React, { useEffect, useRef, useState } from "react";
import { MDBCol, MDBInput, MDBRow, MDBTypography } from "mdbreact";
import { useSelector } from "react-redux";
import Tracks from "../../../../../../services/fakeDb/track";
import Images from "../../../../../../widgets/Image";
import checkIfBlurredImg from "../imageTools/canvasCheckBlurred";
import { useToasts } from "react-toast-notifications";

import "../learner.css";
const jhsOptions = [
  { value: 7, label: "Grade 7" },
  { value: 8, label: "Grade 8" },
  { value: 9, label: "Grade 9" },
  { value: 10, label: "Grade 10" },
];

const Enrollment = ({
  collections,
  setDetails,
  data,
  isNewNReject,
  setUserData,
  handleBlockNextBtn,
}) => {
  const { information } = useSelector(({ auth }) => auth);
  const [isNewStudent, setIsNewStudent] = useState(true);
  const [enrolleeStatus, setEnrolleeStatus] = useState("");
  const [batchSem, setBatchSem] = useState("");
  const [openProgress, setOpenProgress] = useState({
    jhs: false,
    shs: false,
  });
  const [studentStatus, setStudentStatus] = useState({
    transferee: data?.transferee ? data?.transferee : false,
    isICT: data?.isICT ? data?.isICT : false,
  });
  const [isPassed, setIspassed] = useState(false);
  const [lastSchool, setLastSchool] = useState({
    name: "",
    address: "",
  });
  const [pendingStudent, setPendingStudent] = useState(false);

  const imageKeys = ["birthCertificate", "form137", "goodMoral"];
  const initializeImageData = (data) => {
    return imageKeys.reduce((acc, key) => {
      acc[key] =
        data[key] instanceof File ? URL.createObjectURL(data[key]) : data[key];
      return acc;
    }, {});
  };

  const [userDataImage, setUserDataImage] = useState(initializeImageData(data));
  const prevImage = useRef(initializeImageData(data)).current;
  const { addToast } = useToasts();

  /* handler function for stage change like jhs or shs*/
  const handleStageChange = (progress) => {
    const newDetails = {
      progress,
      lvl: progress === "jhs" ? 7 : 11,
      specialization: progress === "jhs" ? "" : data.specialization,
      strand: progress === "jhs" ? "" : data.strand,
    };
    
    setDetails({
      ...data,
      ...newDetails
    });

    setUserData((prev) => ({
      ...prev,
      ...newDetails,
    }));
  };

  // handler function for transferee checkbox
  const handleLearner = (name, checked) => {
    setStudentStatus(prev => ({ ...prev, [name]: checked }));
    
    const newData = { ...data, [name]: checked };
    if (name === "transferee" && !checked) {
      newData.progress = "jhs";
      newData.lvl =  7;
      newData.strand = ""
      newData.specialization = ""
      newData.goodMoral = ""
      newData.form137 = ""
      newData.birthCertificate = ""
      setUserDataImage({
        birthCertificate: "",
        goodMoral: "",
        form137: "",
      })
    }
    setDetails(newData);
    setUserData(prev => ({ ...prev, ...newData }));
  };

  const handleChange = (e) => {
    const { name, value } = e.target;
    const newValue = name === "lvl" ? parseInt(value) : value;
    
    const newData = { ...data, [name]: newValue };
    setDetails(newData);
    setUserData(prev => ({ ...prev, [name]: newValue }));
  };

  const handleLastSchool = (e) => {
    const { name, value } = e.target;
    setLastSchool(prev => ({ ...prev, [name]: value }));
    
    const newData = {
      ...data,
      lastSchool: { ...data.lastSchool, [name]: value }
    };
    setDetails(newData);
    setUserData(prev => ({
      ...prev,
      lastSchool: { ...prev.lastSchool, [name]: value }
    }));
  };

  useEffect(() => {
    if (information.enrolleeData) {
      setIsNewStudent(information.isFreshman);
      setIspassed(information.isPassedInExam);
      setEnrolleeStatus(information.enrolleeData?.status);
    }
  }, [information]);

  useEffect(() => {
    if (!collections) return;

    const batchOpen = collections.filter(item => item.status === "ACTIVE");
    const batchInfo = information.enrolleeData?.batch?._id;

    batchOpen.forEach(active => {
      if (enrolleeStatus === "PENDING" && active.id !== batchInfo) {
        setPendingStudent(true);
      }

      if (active.progress === "jhs" && data.progress === "jhs" && isNewStudent) {
        setOpenProgress(prev => ({ ...prev, jhs: true }));
      } else if (active.progress === "shs") {
        setOpenProgress(prev => ({ ...prev, shs: true }));
        setBatchSem(active.semester);
      }
    });

        // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [collections, data.progress, isNewStudent, enrolleeStatus, information.enrolleeData?.batch?._id]);

  const disabledProgress = (progressType) => {
    if (isNewNReject && !data.transferee) return false;
    if (data.transferee) return false;

    if (progressType === "jhs") {
      if (studentStatus.transferee) return false;
      if (openProgress.jhs && (data.transferee || data.progress === "jhs")) return false;
      return true;
    }

    if (progressType === "shs") {
      if (isNewStudent && !data.transferee) return true;
      if (openProgress.shs && data.progress === "shs" && data.transferee) return false;
      return true;
    }
  };

  const disabledLevelSelection = (value) => {
    if (!openProgress.jhs) return true;
    if (isNewNReject && data.transferee) return false;
    if (isNewStudent && data.transferee) return false;
    if (value === data.lvl && (isNewStudent || enrolleeStatus === "REJECT" || pendingStudent)) return false;
    return true;
  };

  const disabledLevelForShs = (value) => {
    if (!openProgress.shs) return true;
    if (isNewStudent && data.transferee) return false;
    if (value === data.lvl && (enrolleeStatus === "REJECT" || pendingStudent)) return false;
    
    const isCurrentLevel = value === data.lvl;
    const isNextLevel = value === data.lvl + 1;
    const isSecondSem = batchSem === "2nd";
    
    if (!isNewStudent && isCurrentLevel && isPassed && enrolleeStatus !== "REJECT") {
      if (isSecondSem) return false;
      if (!isSecondSem && value !== data.lvl) return false;
    }
    
    if (!isNewStudent && isNextLevel && isPassed && enrolleeStatus !== "REJECT" && !isSecondSem) {
      return true;
    }
    
    return true;
  };

  const handleImgChange = (e) => {
    const { name, files } = e.target;

    if (files.length > 0) {
      const file = files[0];
      setDetails({
        ...data,
        [name]: file,
      });

      const fileUrl = URL.createObjectURL(file);
      setUserDataImage((prev) => ({
        ...prev,
        [name]: fileUrl,
      }));

      const reader = new FileReader();
      reader.onload = function (event) {
        const base64String = event.target.result;
        setUserData((prev) => ({
          ...prev,
          [name]: base64String,
        }));

        const img = new Image();
        img.onload = () => {
          const imgBlurred2 = checkIfBlurredImg(img);
          handleBlockNextBtn(imgBlurred2);

          if (imgBlurred2) {
            addToast(`Error cannot process blurry image of ${name}`, {
              appearance: "error",
            });

            Object.keys(prevImage).forEach((key) => {
              if (key === name) {
                setDetails({
                  ...data,
                  [name]: prevImage[key],
                });

                if (
                  prevImage[key] instanceof Blob ||
                  prevImage[key] instanceof File
                ) {
                  const fileUrl = URL.createObjectURL(prevImage[key]);
                  setUserDataImage((prev) => ({
                    ...prev,
                    [name]: fileUrl,
                  }));
                }
              }
            });
          }
        };
        img.src = base64String;
      };
      reader.readAsDataURL(file);
    }
  };

  return (
    <>
      <MDBRow style={{ backgroundColor: "#0000FF" }}>
        <MDBCol>
          <h5 className="font-weight-bold text-white label mt-2 mb-2 ml-5 section-title">
            V. Enrollment
          </h5>
        </MDBCol>
      </MDBRow>
      {data.isPassedInExam && (
        <MDBTypography
          variant="h2"
          className="mb-0 text-black mt-4"
          noteColor="success"
          note
          noteTitle="Congratulations! "
        >
          You have passed the ICT examination and are now eligible to enroll as
          an ICT student.
        </MDBTypography>
      )}
      {isNewStudent && (
        <>
          <MDBRow className="mt-4 mr-4 ml-4">
            <MDBCol>
              <h6>
                <strong>
                  {" "}
                  <i>For Those Who will Transfer/Move in</i>
                </strong>
              </h6>
            </MDBCol>
          </MDBRow>

          <MDBRow className="mr-2 ml-2 mt-2">
            <MDBCol>
              <MDBInput
                label="Transferee"
                type="checkbox"
                name="transferee"
                checked={studentStatus?.transferee}
                onChange={(e) => handleLearner(e.target.name, e.target.checked)}
                id="transferee"
              />
            </MDBCol>

            {data.isPassedInExam && data.lvl === 7 && (
              <MDBCol>
                <MDBInput
                  label="Enroll as ICT"
                  type="checkbox"
                  name="isICT"
                  checked={studentStatus?.isICT}
                  onChange={(e) =>
                    handleLearner(e.target.name, e.target.checked)
                  }
                  id="isICT"
                />
              </MDBCol>
            )}
          </MDBRow>

          {(studentStatus.transferee || isNewStudent || isNewNReject) && (
            <MDBRow className="mt-4 mr-4 ml-4">
              <MDBCol>
                <h6>Last School Attended</h6>

                <input
                  placeholder="Last School Attended"
                  className="form-control"
                  value={data?.lastSchool?.name || lastSchool.name}
                  name="name"
                  onChange={handleLastSchool}
                />
              </MDBCol>

              <MDBCol>
                <h6>Last School Address</h6>

                <input
                  placeholder="Last School Address"
                  className="form-control"
                  name="address"
                  value={data?.lastSchool?.address || lastSchool.address}
                  onChange={handleLastSchool}
                />
              </MDBCol>
            </MDBRow>
          )}
        </>
      )}

      {batchSem && data.progress === "shs" && (
        <MDBRow className="mt-4 mr-4 ml-4">
          <MDBCol>
            <h6>
              <b>{batchSem} Semester</b>
            </h6>
          </MDBCol>
        </MDBRow>
      )}

      <MDBRow className="mt-4 mr-4 ml-4">
        <MDBCol>
          <h6>
            <strong>Level</strong>
          </h6>
          <select
            name="progress"
            value={data.progress}
            className="form-control"
            onChange={(e) => handleStageChange(e.target.value)}
          >
            <option value="jhs" disabled={disabledProgress("jhs")}>
              JHS
            </option>

            <option value="shs" disabled={disabledProgress("shs")}>
              SHS
            </option>
          </select>
        </MDBCol>

        <MDBCol>
          <h6>
            <strong>Grade Level</strong>
          </h6>
          <select
            name="lvl"
            value={data.lvl ? data.lvl : "7"}
            className="form-control"
            onChange={(e) => handleChange(e)}
          >
            {data.progress === "jhs" ? (
              <>
                {jhsOptions.map((option, i) => (
                  <option
                    key={i}
                    value={option.value}
                    disabled={disabledLevelSelection(option.value)}
                  >
                    {option.label}
                  </option>
                ))}
              </>
            ) : (
              data.progress === "shs" && (
                <>
                  <option disabled={disabledLevelForShs(11)} value={String(11)}>
                    Grade 11
                  </option>
                  <option disabled={disabledLevelForShs(12)} value={String(12)}>
                    Grade 12
                  </option>
                </>
              )
            )}
          </select>
        </MDBCol>
      </MDBRow>

      {data.progress === "shs" && (
        <MDBRow className="mt-4 mr-4 ml-4">
          <MDBCol>
            <h6>
              <strong>Specialization</strong>
            </h6>
            <select
              name="specialization"
              value={data.specialization}
              className="form-control"
              onChange={(e) => handleChange(e)}
            >
              <option>Choose specialization</option>
              {Tracks.collections.map((track) => (
                <option key={track.name} value={track.name}>
                  {track.name}
                </option>
              ))}
            </select>
          </MDBCol>

          <MDBCol>
            <h6>
              <strong>Strand</strong>
            </h6>
            <select
              name="strand"
              value={data.strand}
              className="form-control"
              onChange={(e) => handleChange(e)}
            >
              <option>Choose strand</option>
              {Tracks.getStrand(data.specialization)
                ?.filter((strd) =>
                  strd.abbr === "ICT" ? data.isPassedInExam : true
                )
                ?.map((strand) => (
                  <option key={strand.abbr} value={strand.abbr}>
                    {strand.name}
                  </option>
                ))}
            </select>
          </MDBCol>
        </MDBRow>
      )}
      <MDBRow className="mt-4 mr-4 ml-4">
        {studentStatus.transferee && (
          <Images
          userDataImage={userDataImage}
          handleChange={handleImgChange}
          viewOnly={false}
          imageTypes={["birthCertificate", "form137", "goodMoral"]}
          />
        )}
      </MDBRow>

      <MDBRow>
        <MDBCol>
          <p style={{textIndent: '2em', padding: "0 2em"}}>I hereby certify that the information provided above is true and correct to the best of my knowledge. 
            I grant permission for my details to be used by the Department of Education to create or update my learner profile in the Learner Information System. 
            All information will be treated as confidential in compliance with the <strong>Data Privacy Act of 2012.</strong>
          </p>
        </MDBCol>
      </MDBRow>
    </>
  );
};

export default Enrollment;



      /* setDetails({
        ...data,
        progress: isRegistrar ? prevData.progress : "jhs",
        lvl: isRegistrar ? prevData.lvl : 7,
      });

      setUserData((prev) => ({
        ...prev,
        progress: isRegistrar ? prevData.progress : "jhs",
        lvl: isRegistrar ? prevData.lvl : 7,
      })); */